item(FEAT_TRAINS, DTX_Logo, 1042){
    property {
        name:                           string(STR_Group_DTX_Logo_NAME);
        climates_available:             NO_CLIMATE;
        track_type:                     ELRL;
        engine_class:                   ENGINE_CLASS_ELECTRIC;
        sprite_id:                      SPRITE_ID_NEW_TRAIN;
        power:                          40000 kW;
        }

    graphics {
        purchase:                       set_DTX_purchase;
        }
        }

