//도색명
switch(FEAT_TRAINS, SELF, sw_DTS_CityLink_150_1st_speed_cargo_subtype_text, cargo_subtype) {
    1: return string(STR_REFIT_LIVERY_DTS_CityLink_180_speed);
    return string(STR_REFIT_LIVERY_DTS_CityLink_150_speed);
}

