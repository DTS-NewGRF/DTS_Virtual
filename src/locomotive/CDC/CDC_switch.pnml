    VEH_KEY_SUB_POS_MODE(1,2,1): set_CDC_New_wagon_r;
    VEH_KEY_SUB_POS_MODE(1,3,1): set_CDC_New_engineH_r;

    /* subtype 2: Flower_Garden */
    VEH_KEY_SUB_POS_MODE(2,0,0): set_CDC_Flower_Garden_engineH;
    VEH_KEY_SUB_POS_MODE(2,1,0): set_CDC_Flower_Garden_wagon;
    VEH_KEY_SUB_POS_MODE(2,2,0): set_CDC_Flower_Garden_wagon;
    VEH_KEY_SUB_POS_MODE(2,3,0): set_CDC_Flower_Garden_engineT;

