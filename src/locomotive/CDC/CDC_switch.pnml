    VEH_KEY_SUB_POS_MODE(3,3,1): set_CDC_Baekje_Crown_engineH_r;

    /* subtype 4: Sea_New */
    VEH_KEY_SUB_POS_MODE(4,0,0): set_CDC_Sea_New_engineH;
    VEH_KEY_SUB_POS_MODE(4,1,0): set_CDC_Sea_New_wagon_M1;
    VEH_KEY_SUB_POS_MODE(4,2,0): set_CDC_Sea_New_wagon_M2;
    VEH_KEY_SUB_POS_MODE(4,3,0): set_CDC_Sea_New_engineT;

    VEH_KEY_SUB_POS_MODE(4,0,1): set_CDC_Sea_New_engineT_r;
    VEH_KEY_SUB_POS_MODE(4,1,1): set_CDC_Sea_New_wagon_M2_r;
    VEH_KEY_SUB_POS_MODE(4,2,1): set_CDC_Sea_New_wagon_M1_r;
    VEH_KEY_SUB_POS_MODE(4,3,1): set_CDC_Sea_New_engineH_r;

    return set_CDC_Old_engineH;
    }

